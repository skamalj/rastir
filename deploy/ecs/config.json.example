{
  "deploy": {
    "aws_region": "ap-south-1",
    "stack_name": "rastir-server",
    "vpc_id": "vpc-xxxxxxxx",
    "subnet_ids": "subnet-aaa,subnet-bbb",
    "assign_public_ip": "ENABLED",
    "fargate_cpu": "512",
    "fargate_memory": "1024",
    "desired_count": 1,
    "rastir_image": "ghcr.io/skamalj/rastir-server:latest",
    "amp_remote_write_endpoint": "https://aps-workspaces.us-east-1.amazonaws.com/workspaces/ws-xxxxx/api/v1/remote_write",
    "amp_region": "us-east-1",
    "rastir_server_port": 8080
  },
  "server": {
    "port": 8080,
    "logging": {
      "level": "INFO",
      "structured": true
    },
    "trace_store": {
      "enabled": true
    },
    "sampling": {
      "rate": 1.0
    },
    "redaction": {
      "enabled": true
    },
    "evaluation": {
      "enabled": true,
      "judge_model": "gpt-4o-mini",
      "judge_provider": "openai",
      "worker_concurrency": 4
    },
    "exemplars": {
      "enabled": true
    },
    "exporter": {
      "otlp_endpoint": "http://localhost:4318",
      "batch_size": 200,
      "flush_interval": 5
    },
    "sre": {
      "enabled": true,
      "default_slo_error_rate": 0.01,
      "default_cost_budget_usd": 25.0,
      "agents": {
        "langgraph_e2e_agent": {
          "slo_error_rate": 0.02
        },
        "openai_agent": {
          "slo_error_rate": 0.01
        }
      }
    }
  },
  "secrets": {
    "OPENAI_API_KEY": "secretsmanager:arn:aws:secretsmanager:us-east-1:123456789012:secret:rastir/openai-key"
  }
}
