# ---------------------------------------------------------------------------
# Rastir ECS Deployment Configuration
# ---------------------------------------------------------------------------
# Copy to config.env and edit before deploying:
#   cp config.env.example config.env
#   vi config.env
#   ./deploy.sh
#
# Secret value prefixes:
#   secretsmanager:<arn>   — ECS resolves from Secrets Manager at task start
#   ssm:<arn>              — ECS resolves from SSM Parameter Store at task start
#   env:<VAR_NAME>         — Resolved from local/CI environment at deploy time
#   (no prefix)            — Plain literal value (dev/testing only)
# ---------------------------------------------------------------------------

# ── AWS / Deployment ─────────────────────────────────────────────────────────
AWS_REGION=us-east-1
STACK_NAME=rastir-server

# ── Infrastructure ───────────────────────────────────────────────────────────
VPC_ID=vpc-xxxxxxxx
SUBNET_IDS=subnet-aaa,subnet-bbb
FARGATE_CPU=512
FARGATE_MEMORY=1024
DESIRED_COUNT=1

# ── Rastir Server Image ─────────────────────────────────────────────────────
RASTIR_IMAGE=ghcr.io/skamalj/rastir-server:latest

# ── Amazon Managed Prometheus ────────────────────────────────────────────────
AMP_REMOTE_WRITE_ENDPOINT=https://aps-workspaces.us-east-1.amazonaws.com/workspaces/ws-xxxxx/api/v1/remote_write
AMP_REGION=us-east-1

# ── Rastir Server Configuration ─────────────────────────────────────────────
RASTIR_SERVER_PORT=8080
RASTIR_SERVER_LOGGING_LEVEL=INFO
RASTIR_SERVER_LOGGING_STRUCTURED=true
RASTIR_SERVER_TRACE_STORE_ENABLED=true
RASTIR_SERVER_REDACTION_ENABLED=true
RASTIR_SERVER_EVALUATION_ENABLED=true
RASTIR_SERVER_EVALUATION_JUDGE_MODEL=gpt-4o-mini
RASTIR_SERVER_EVALUATION_WORKER_CONCURRENCY=4
RASTIR_SERVER_SRE_ENABLED=true
RASTIR_SERVER_SRE_DEFAULT_SLO_ERROR_RATE=0.01
RASTIR_SERVER_SAMPLING_RATE=1.0

# ── Secrets ──────────────────────────────────────────────────────────────────
# Use one of: secretsmanager:<arn>  |  ssm:<arn>  |  env:<VAR>  |  plain-value
OPENAI_API_KEY=secretsmanager:arn:aws:secretsmanager:us-east-1:123456789012:secret:rastir/openai-key
# ANTHROPIC_API_KEY=ssm:arn:aws:ssm:us-east-1:123456789012:parameter/rastir/anthropic-key
# GEMINI_API_KEY=env:GEMINI_API_KEY
