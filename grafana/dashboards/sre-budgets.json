    {
      "id": 13,
      "title": "Error & Cost Budget Burn Rate",
      "description": "Error and cost budget remaining over time \u2014 starts at 100% and burns down to 0%",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 11
      },
      "targets": [
        {
          "expr": "clamp_min(100 * (1 - sum(rastir:errors:$period{service=~\"$service\",env=~\"$env\",agent=~\"$agent\"}) / sum(rastir:error_budget_total:$period{service=~\"$service\",env=~\"$env\",agent=~\"$agent\"})), 0)",
          "legendFormat": "Error Budget Remaining %",
          "refId": "A"
        },
        {
          "expr": "clamp_min(100 * (1 - sum(rastir:cost:$period) / scalar(rastir_cost_budget_usd{agent=\"unknown\"})), 0)",
          "legendFormat": "Cost Budget Remaining %",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "min": 0,
          "max": 100,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 8,
            "spanNulls": true,
            "lineWidth": 2,
            "gradientMode": "opacity",
            "axisSoftMin": 0,
            "axisSoftMax": 100,
            "thresholdsStyle": {
              "mode": "area"
            },
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "axisBorderShow": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "#ff9830",
                "value": 25
              },
              {
                "color": "green",
                "value": 75
              }
            ]
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [
            "lastNotNull"
          ]
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      }
    },
