      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 34 },
      "targets": [
        {
          "expr": "rastir_cost_budget_remaining{service=~\"$service\",env=~\"$env\",agent=~\"$agent\",period=\"$period\"}",
          "legendFormat": "{{agent}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
