    },
    {
      "id": 33,
      "title": "Cost Burn Rate ($/day)",
      "description": "Average daily cost burn rate per agent",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 42 },
      "targets": [
        {
          "expr": "rastir_cost_burn_rate_daily{service=~\"$service\",env=~\"$env\",agent=~\"$agent\",period=\"$period\"}",
          "legendFormat": "{{agent}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
