{
  "uid": "rastir-sre-budgets",
  "id": 7,
  "title": "Rastir SRE — Budgets & Burn Rates",
  "description": "SLO/SLA tracking, error & cost budgets, burn rates, exhaustion projections",
  "tags": ["rastir", "llm-observability", "sre", "slo", "budget"],
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "style": "dark",
  "templating": {
    "list": [
      {
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(rastir_expected_volume, service)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "service",
        "options": [],
        "query": "label_values(rastir_expected_volume, service)",
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      },
      {
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(rastir_expected_volume, env)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "env",
        "options": [],
        "query": "label_values(rastir_expected_volume, env)",
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      },
      {
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(rastir_expected_volume, agent)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "agent",
        "options": [],
        "query": "label_values(rastir_expected_volume, agent)",
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      },
      {
        "current": { "selected": true, "text": "week", "value": "week" },
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "name": "period",
        "options": [
          { "selected": true, "text": "week", "value": "week" },
          { "selected": false, "text": "month", "value": "month" }
        ],
        "query": "week,month",
        "type": "custom"
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "SLA Status & Overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 1,
      "title": "SLA Status",
      "description": "1 = Healthy (error budget remaining), 0 = Breached",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "rastir_sla_status{service=~\"$service\",env=~\"$env\",agent=~\"$agent\",period=\"$period\"}",
          "legendFormat": "{{agent}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "BREACHED", "color": "red" } } },
            { "type": "value", "options": { "1": { "text": "HEALTHY", "color": "green" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 2,
      "title": "Expected Volume",
      "description": "Rolling request volume used to estimate allowed budget",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 4, "x": 4, "y": 1 },
      "targets": [
        {
          "expr": "sum(rastir_expected_volume{service=~\"$service\",env=~\"$env\",agent=~\"$agent\",period=\"$period\"})",
          "legendFormat": "Expected Volume",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      }
    },
    {
      "id": 3,
      "title": "Error Budget Total",
      "description": "Total allowed errors = expected_volume × SLO error rate",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 4, "x": 8, "y": 1 },
      "targets": [
        {
          "expr": "sum(rastir_error_budget_total{service=~\"$service\",env=~\"$env\",agent=~\"$agent\",period=\"$period\"})",
          "legendFormat": "Error Budget",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      }
    },
    {
      "id": 4,
      "title": "Error Budget Remaining",
      "description": "Remaining allowed errors before SLA breach",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 4, "x": 12, "y": 1 },
      "targets": [
        {
          "expr": "sum(rastir_error_budget_remaining{service=~\"$service\",env=~\"$env\",agent=~\"$agent\",period=\"$period\"})",
          "legendFormat": "Remaining",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 5 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      }
    },
    {
      "id": 5,
      "title": "Cost Budget Remaining ($)",
      "description": "Remaining cost budget for the current period",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 4, "x": 16, "y": 1 },
      "targets": [
        {
          "expr": "sum(rastir_cost_budget_remaining{service=~\"$service\",env=~\"$env\",agent=~\"$agent\",period=\"$period\"})",
          "legendFormat": "Cost Remaining",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "green", "value": 50 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      }
    },
    {
      "id": 6,
      "title": "Error Days to Exhaustion",
      "description": "Estimated days until error budget runs out",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 4, "x": 20, "y": 1 },
      "targets": [
        {
          "expr": "min(rastir_error_days_to_exhaustion{service=~\"$service\",env=~\"$env\",agent=~\"$agent\",period=\"$period\"})",
          "legendFormat": "Days Left",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "green", "value": 7 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      }
    },

    {
      "id": 101,
      "type": "row",
      "title": "Error Budget",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 10,
      "title": "Error Budget Consumed (%)",
      "description": "Percentage of error budget consumed per agent",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rastir_error_budget_consumed_percent{service=~\"$service\",env=~\"$env\",agent=~\"$agent\",period=\"$period\"}",
          "legendFormat": "{{agent}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "min": 0,
          "max": 150,
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "orange", "value": 80 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "minVizHeight": 75,
        "minVizWidth": 75
      }
    },
    {
      "id": 11,
      "title": "Error Budget Remaining (trend)",
      "description": "Error budget remaining over time per agent",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "targets": [
        {
          "expr": "rastir_error_budget_remaining{service=~\"$service\",env=~\"$env\",agent=~\"$agent\",period=\"$period\"}",
          "legendFormat": "{{agent}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "spanNulls": true,
            "lineWidth": 2,
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 0 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 12,
      "title": "Error Budget Consumed % (trend)",
      "description": "Error budget consumed percentage over time",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "targets": [
        {
          "expr": "rastir_error_budget_consumed_percent{service=~\"$service\",env=~\"$env\",agent=~\"$agent\",period=\"$period\"}",
          "legendFormat": "{{agent}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "spanNulls": true,
            "lineWidth": 2,
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 100 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      }
    },

    {
      "id": 102,
      "type": "row",
      "title": "Burn Rates",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 20,
      "title": "Error Burn Rate — Short (1h)",
      "description": "Short-window burn rate: error_rate_1h / SLO. >1 = consuming budget faster than allowed",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 17 },
      "targets": [
        {
          "expr": "rastir_error_burn_rate_short{service=~\"$service\",env=~\"$env\",agent=~\"$agent\"}",
          "legendFormat": "{{agent}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "spanNulls": true,
            "lineWidth": 2,
            "thresholdsStyle": { "mode": "line+area" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "transparent", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      }
    },
    {
      "id": 21,
      "title": "Error Burn Rate — Long (6h)",
      "description": "Long-window burn rate: error_rate_6h / SLO. Sustained >1 = fast budget depletion",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 17 },
      "targets": [
        {
          "expr": "rastir_error_burn_rate_long{service=~\"$service\",env=~\"$env\",agent=~\"$agent\"}",
          "legendFormat": "{{agent}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "spanNulls": true,
            "lineWidth": 2,
            "thresholdsStyle": { "mode": "line+area" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "transparent", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      }
    },
    {
      "id": 22,
      "title": "Error Days to Exhaustion (trend)",
      "description": "Projected days until error budget runs out per agent",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 25 },
      "targets": [
        {
          "expr": "rastir_error_days_to_exhaustion{service=~\"$service\",env=~\"$env\",agent=~\"$agent\",period=\"$period\"} < 9999",
          "legendFormat": "{{agent}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1,
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 5,
            "spanNulls": true,
            "lineWidth": 2,
            "thresholdsStyle": { "mode": "line+area" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "green", "value": 7 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "min"] }
      }
    },
    {
      "id": 23,
      "title": "Expected Volume (trend)",
      "description": "Rolling expected request volume used for budget estimation",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 25 },
      "targets": [
        {
          "expr": "rastir_expected_volume{service=~\"$service\",env=~\"$env\",agent=~\"$agent\",period=\"$period\"}",
          "legendFormat": "{{agent}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "spanNulls": true,
            "lineWidth": 2
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] }
      }
    },

    {
      "id": 103,
      "type": "row",
      "title": "Cost Budget",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 33 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 30,
      "title": "Cost Budget Consumed (%)",
      "description": "Percentage of cost budget consumed per agent",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 34 },
