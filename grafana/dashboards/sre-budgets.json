      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 32,
      "title": "Cost Budget Consumed % (trend)",
      "description": "Cost budget consumed percentage over time",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 34 },
      "targets": [
        {
          "expr": "rastir_cost_budget_consumed_percent{service=~\"$service\",env=~\"$env\",agent=~\"$agent\",period=\"$period\"}",
          "legendFormat": "{{agent}}",
