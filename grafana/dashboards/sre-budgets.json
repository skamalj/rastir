        "x": 10,
        "y": 6
      },
      "targets": [
        {
          "expr": "100 * (1 - sum(rastir:errors:$period{service=~\"$service\",env=~\"$env\",agent=~\"$agent\"}) / sum(rastir:error_budget_total:$period{service=~\"$service\",env=~\"$env\",agent=~\"$agent\"}))",
