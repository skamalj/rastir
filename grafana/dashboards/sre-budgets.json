            "lineWidth": 2
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "mean", "max"] }
      }
    },
    {
      "id": 34,
      "title": "Cost Days to Exhaustion (trend)",
      "description": "Projected days until cost budget runs out per agent",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 42 },
      "targets": [
        {
