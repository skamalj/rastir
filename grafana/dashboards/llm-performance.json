{
  "uid": "rastir-llm-performance",
  "id": 2,
  "title": "Rastir LLM Performance",
  "description": "LLM call performance, latency, token usage, and error tracking",
  "tags": ["rastir", "llm-observability"],
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "style": "dark",
  "templating": {
    "list": [
      {
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(rastir_spans_ingested_total, service)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "service",
        "options": [],
        "query": "label_values(rastir_spans_ingested_total, service)",
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      },
      {
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(rastir_spans_ingested_total, env)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "env",
        "options": [],
        "query": "label_values(rastir_spans_ingested_total, env)",
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      },
      {
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(rastir_llm_calls_total, model)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "model",
        "options": [],
        "query": "label_values(rastir_llm_calls_total, model)",
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      },
      {
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(rastir_llm_calls_total, provider)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "provider",
        "options": [],
        "query": "label_values(rastir_llm_calls_total, provider)",
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      },
      {
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(rastir_llm_calls_total, agent)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "agent",
        "options": [],
        "query": "label_values(rastir_llm_calls_total, agent)",
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "panels": [
    {
      "id": 16,
      "type": "stat",
      "title": "Total LLM Calls",
      "description": "Total LLM calls in selected period",
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(rastir_llm_calls_total{service=~\"$service\", env=~\"$env\", model=~\"$model\", provider=~\"$provider\", agent=~\"$agent\"}[$__range]))",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#5794F2" },
          "mappings": [],
          "unit": "none",
          "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "white", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "id": 17,
      "type": "stat",
      "title": "Total Errors",
      "description": "Total LLM errors in selected period",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(rastir_errors_total{span_type=\"llm\", service=~\"$service\", env=~\"$env\", model=~\"$model\", provider=~\"$provider\"}[$__range]))",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "#C4162A" },
          "mappings": [],
          "unit": "none",
          "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "white", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": false, "calcs": ["lastNotNull"], "fields": "" },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto",
        "wideLayout": true
      }
    },
    {
      "id": 1,
      "type": "row",
      "title": "LLM Throughput",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 4 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "type": "piechart",
      "title": "LLM Calls by Model & Provider",
      "description": "Total LLM calls in selected period broken down by model and provider",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(rastir_llm_calls_total{service=~\"$service\", env=~\"$env\", model=~\"$model\", provider=~\"$provider\", agent=~\"$agent\"}[$__range])) by (model, provider)",
          "legendFormat": "{{model}} / {{provider}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "mappings": [],
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "values": true, "calcs": ["lastNotNull"], "fields": "" },
        "pieType": "donut",
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "right", "showLegend": true, "values": ["value", "percent"] }
      }
    },
    {
      "id": 12,
      "type": "table",
      "title": "LLM Calls — Breakdown",
      "description": "Tabular view of total LLM calls per model/provider in selected period",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(rastir_llm_calls_total{service=~\"$service\", env=~\"$env\", model=~\"$model\", provider=~\"$provider\", agent=~\"$agent\"}[$__range])) by (model, provider)",
          "legendFormat": "{{model}} / {{provider}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "instant": true,
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "unit": "short",
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "custom": { "align": "auto", "cellOptions": { "type": "color-text" }, "inspect": false }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Time" }, "properties": [{ "id": "custom.hidden", "value": true }] },
          { "matcher": { "id": "byName", "options": "Value" }, "properties": [{ "id": "displayName", "value": "Total Calls" }] }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Total Calls", "desc": true }],
        "footer": { "show": true, "reducer": ["sum"], "countRows": false, "fields": ["Value"] }
      }
    },
    {
      "id": 3,
      "type": "row",
      "title": "Latency",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "LLM Latency Percentiles",
      "description": "p50, p95, and p99 latency for LLM calls",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum(rate(rastir_duration_seconds_bucket{span_type=\"llm\", service=~\"$service\", env=~\"$env\", model=~\"$model\", provider=~\"$provider\"}[5m])) by (le, model, provider))",
          "legendFormat": "p50 {{model}} / {{provider}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum(rate(rastir_duration_seconds_bucket{span_type=\"llm\", service=~\"$service\", env=~\"$env\", model=~\"$model\", provider=~\"$provider\"}[5m])) by (le, model, provider))",
          "legendFormat": "p95 {{model}} / {{provider}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum(rate(rastir_duration_seconds_bucket{span_type=\"llm\", service=~\"$service\", env=~\"$env\", model=~\"$model\", provider=~\"$provider\"}[5m])) by (le, model, provider))",
          "legendFormat": "p99 {{model}} / {{provider}}",
          "datasource": { "type": "prometheus", "uid": "prometheus" }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 5,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "insertNulls": false,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 30 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
