    {
      "id": 6,
      "type": "timeseries",
      "title": "Evaluation Latency Percentiles",
      "description": "p50 and p95 evaluation latency by evaluation type",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum(rate(rastir_evaluation_latency_seconds_bucket{service=~\"$service\", env=~\"$env\", model=~\"$model\", provider=~\"$provider\", evaluation_type=~\"$evaluation_type\"}[5m])) by (le, evaluation_type))",
          "legendFormat": "p50 {{evaluation_type}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum(rate(rastir_evaluation_latency_seconds_bucket{service=~\"$service\", env=~\"$env\", model=~\"$model\", provider=~\"$provider\", evaluation_type=~\"$evaluation_type\"}[5m])) by (le, evaluation_type))",
          "legendFormat": "p95 {{evaluation_type}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          }
