    {
      "id": 1,
      "type": "row",
      "title": "Evaluation Throughput",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 4
      },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "type": "piechart",
      "title": "Evaluations by Type (${eval_status:text})",
      "description": "Evaluation breakdown by type, filtered by status",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "(sum(increase(rastir_evaluation_runs_total{service=~\"$service\", env=~\"$env\", model=~\"$model\", provider=~\"$provider\", evaluation_type=~\"$evaluation_type\"}[$__range])) by (evaluation_type) * scalar(vector(1) - floor(vector($eval_status) / 2)) + sum(increase(rastir_evaluation_failures_total{service=~\"$service\", env=~\"$env\", model=~\"$model\", provider=~\"$provider\", evaluation_type=~\"$evaluation_type\"}[$__range])) by (evaluation_type) * scalar(sgn(vector($eval_status)) * (2 * vector($eval_status) - 3))) > 0",
          "legendFormat": "{{evaluation_type}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "mappings": [],
          "unit": "short",
          "decimals": 0,
          "custom": {}
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": true,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "pieType": "donut",
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "values": [
            "value",
            "percent"
          ]
        }
      }
    },
    {
      "id": 22,
      "type": "piechart",
      "title": "Evaluations by Model (${eval_status:text})",
      "description": "Evaluation breakdown by model, filtered by status",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 5
      },
      "datasource": {
        "type": "prometheus",
