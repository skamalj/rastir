          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "pieType": "donut",
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "values": [
            "value",
            "percent"
          ]
        }
