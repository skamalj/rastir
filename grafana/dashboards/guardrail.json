      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(rastir_guardrail_violations_total{service=~\"$service\", env=~\"$env\", model=~\"$model\", provider=~\"$provider\", agent=~\"$agent\"}[$__range])) by (guardrail_category) > 0",
          "legendFormat": "{{guardrail_category}}",
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
