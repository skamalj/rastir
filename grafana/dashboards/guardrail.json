          {
            "matcher": {
              "id": "byName",
              "options": "Time"
            },
            "properties": [
              {
                "id": "custom.hidden",
                "value": true
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "desc": true,
            "displayName": "Violations"
          }
        ],
        "footer": {
          "show": true,
          "reducer": [
            "sum"
          ],
          "countRows": false
        }
      }
    },
