{
  "uid": "rastir-system-health",
  "id": 1,
  "title": "Rastir System Health",
  "description": "System health monitoring for Rastir LLM observability server",
  "tags": ["rastir", "llm-observability"],
  "schemaVersion": 39,
  "version": 1,
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "style": "dark",
  "templating": {
    "list": [
      {
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(rastir_spans_ingested_total, service)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "service",
        "options": [],
        "query": "label_values(rastir_spans_ingested_total, service)",
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      },
      {
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(rastir_spans_ingested_total, env)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "env",
        "options": [],
        "query": "label_values(rastir_spans_ingested_total, env)",
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query"
      },
      {
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
